# Base URL the app uses for API calls.
# In dev, this is relative (/api) because Vite proxies it to VITE_DEV_PROXY_TARGET.
VITE_API_URL=/api

# gRPC wire format used by ConnectRPC in development.
# false => JSON, true => protobuf binary.
VITE_GRPC_USE_BINARY=false

# Target the Vite dev-server proxy forwards /api requests to.
VITE_DEV_PROXY_TARGET=http://127.0.0.1:8080
